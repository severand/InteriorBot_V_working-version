# ========================================
# ОКРУЖЕНИЕ ДЛЯ .env.example
# ЗАПОЛННЫЕ ПОЛНЕ
# [2025-12-23] ОБНОВЛЕНО: Добавлены переменные для prompt translation
# ========================================

# ========================================
# TELEGRAM БОТ
# ========================================
BOT_TOKEN=your_telegram_bot_token_here

# ========================================
# KIE.AI API (главные нейросети)
# ========================================
KIE_API_KEY=your_kie_api_key_here
USE_KIE_API=True

# ========================================
# REPLICATE API (fallback при недоступности KIE.AI)
# ========================================
REPLICATE_API_TOKEN=your_replicate_api_token_here

# ========================================
# ПЕРЕВОД ПРОМПТОВ [НОВОЕ 2025-12-23]
# ========================================
# БОЛОТ ТО РУС -> АНГ перед отправкой в API
USE_PROMPT_TRANSLATION=True

# ЭКРАН: какой провайдер использовать для перевода?
# ОПЦИИ: google_translate | yandex | libre_translate
TRANSLATION_PROVIDER=google_translate

# ОПЦИО: Google Translate API
# Получить токен: https://cloud.google.com/translate/docs/basic/setup
GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key_here

# ОПЦИО: Yandex Translate API
# Получить токен: https://cloud.yandex.com/docs/translate/api-ref/
YANDEX_TRANSLATE_API_KEY=your_yandex_translate_api_key_here

# ОПЦИО: LibreTranslate (open-source вариант)
# Можно использовать внешние серверы или LibreTranslate ОНЛАЙН
LIBRE_TRANSLATE_URL=https://libretranslate.de/translate
LIBRE_TRANSLATE_API_KEY=your_libre_translate_api_key_here

# ========================================
# DATABASE (НЕ ОБЯЗАТЕЛО)
# ========================================
DATABASE_URL=sqlite:///./interior_bot.db

# ========================================
# LOG LEVEL
# ========================================
LOG_LEVEL=INFO
# ОПЦИИ: DEBUG | INFO | WARNING | ERROR | CRITICAL

# ========================================
# ДОДАТОЧНЫЕ ПАРАМЕТРЫ
# ========================================
API_REQUEST_TIMEOUT=300
